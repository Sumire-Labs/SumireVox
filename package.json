    "test": "pnpm -r test",
    "deploy-commands": "pnpm --filter @sumirevox/bot deploy-commands"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@discordjs/opus", "@prisma/client", "@prisma/engines", "esbuild", "prisma", "sodium-native"]
  }
}

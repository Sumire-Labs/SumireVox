{
  "name": "sumirevox",
  "private": true,
  "scripts": {
    "dev:bot": "pnpm --filter @sumirevox/bot dev",
    "dev:api": "pnpm --filter @sumirevox/api dev",
    "dev:web": "pnpm --filter @sumirevox/web dev",
    "dev:admin": "pnpm --filter @sumirevox/admin dev",
    "build": "pnpm -r build",

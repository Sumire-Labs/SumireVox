# ===========================
# SumireVox 環境変数
# ===========================

# --- Node ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Discord（必須：自分で設定） ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# スラッシュコマンド登録先ギルドID (設定時はギルドコマンド/未設定時はグローバル)
DEPLOY_GUILD_ID=

# --- Database ---
# Bot シャード: connection_limit=3 / API サーバー: connection_limit=5
DATABASE_URL=postgresql://sumirevox:sumirevox_dev@localhost:5432/sumirevox?connection_limit=3

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- VOICEVOX ---
VOICEVOX_URLS=http://localhost:50021
DEFAULT_SPEAKER_ID=1
MAX_CONCURRENT_SYNTHESIS_PER_GUILD=2
MAX_CONCURRENT_SYNTHESIS_GLOBAL=10
HEALTH_CHECK_INTERVAL_SECONDS=30

# --- Bot 動作設定 ---
VOICE_DISCONNECT_TIMEOUT_SECONDS=300
SETTINGS_CACHE_TTL_SECONDS=300

# Bot 管理者のユーザーID (カンマ区切り、空でも可)
BOT_ADMIN_USER_IDS=

# グローバル辞書申請の通知チャンネルID (空の場合は通知なし)
GLOBAL_DICT_NOTIFICATION_CHANNEL_ID=

# --- API サーバー ---
API_PORT=3000
SESSION_SECRET=dev-session-secret-change-in-production
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# --- ドメイン設定 ---
WEB_DOMAIN=http://localhost:5173
ADMIN_DOMAIN=http://localhost:5174

# --- Stripe（ブースト機能を使わない場合は空のまま可） ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
BOOST_COOLDOWN_DAYS=7

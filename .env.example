# ===========================
# アプリケーション設定
# ===========================

# Node.js 実行環境 (development / production)
NODE_ENV=development

# ===========================
# Discord 設定
# ===========================

# Discord Bot トークン (必須)
DISCORD_TOKEN=

# Discord アプリケーションのクライアントID (必須)
DISCORD_CLIENT_ID=

# Discord OAuth2 クライアントシークレット (必須)
DISCORD_CLIENT_SECRET=

# スラッシュコマンド登録先ギルドID (設定時はギルドコマンド/未設定時はグローバル)
DEPLOY_GUILD_ID=

# ===========================
# データベース設定
# ===========================

# PostgreSQL 接続URL (?connection_limit=N を付与すること)
# Bot シャード: connection_limit=3 / API サーバー: connection_limit=5
DATABASE_URL=postgresql://user:password@localhost:5432/sumirevox?connection_limit=3

# ===========================
# Redis 設定
# ===========================

# Redis 接続URL (必須)
REDIS_URL=redis://localhost:6379

# ===========================
# VOICEVOX 設定
# ===========================

# VOICEVOX ENGINE の URL (カンマ区切りで複数指定可能)
VOICEVOX_URLS=http://localhost:50021

# デフォルト話者ID (必須)
DEFAULT_SPEAKER_ID=1

# ギルドあたりの同時音声合成上限数
MAX_CONCURRENT_SYNTHESIS_PER_GUILD=3

# 全シャード合計の同時音声合成上限数
MAX_CONCURRENT_SYNTHESIS_GLOBAL=10

# VOICEVOX ヘルスチェック間隔 (秒) (必須)
HEALTH_CHECK_INTERVAL_SECONDS=30

# ===========================
# Bot 動作設定
# ===========================

# VC 自動退出までのタイムアウト秒数 (必須)
VOICE_DISCONNECT_TIMEOUT_SECONDS=300

# 設定キャッシュの TTL (秒) (必須)
SETTINGS_CACHE_TTL_SECONDS=300

# Bot 管理者のユーザーID (カンマ区切りで複数指定可能) (必須)
BOT_ADMIN_USER_IDS=

# グローバル辞書申請の通知チャンネルID (必須)
GLOBAL_DICT_NOTIFICATION_CHANNEL_ID=

# ===========================
# API サーバー設定
# ===========================

# API サーバーのポート番号
API_PORT=3000

# セッション署名シークレット (必須)
SESSION_SECRET=

# CORS 許可オリジン (カンマ区切り) (必須)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ログレベル (fatal / error / warn / info / debug / trace)
LOG_LEVEL=info

# ===========================
# Stripe 設定
# ===========================

# Stripe シークレットキー (必須)
STRIPE_SECRET_KEY=

# Stripe Webhook 署名シークレット (必須)
STRIPE_WEBHOOK_SECRET=

# ブースト用 Stripe Price ID (必須)
STRIPE_PRICE_ID=

# ブースト付け替えクールダウン日数
BOOST_COOLDOWN_DAYS=7

# ===========================
# ドメイン設定
# ===========================

# メインサイトのドメイン (必須)
WEB_DOMAIN=http://localhost:5173

# 管理者ダッシュボードのドメイン (必須)
ADMIN_DOMAIN=http://localhost:5174

# Node
NODE_ENV=production

# Database
DB_USER=sumirevox
DB_PASSWORD=（強力なパスワードを設定）
DB_NAME=sumirevox

# Redis
REDIS_PASSWORD=（強力なパスワードを設定）

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Bot トークン (インスタンスごとに DISCORD_TOKEN_1, DISCORD_TOKEN_2, ... を設定)
DISCORD_TOKEN_1=

# API Domain (OAuth callback で使用)
API_DOMAIN=https://api.sumirevox.com

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=

# Domains
WEB_DOMAIN=https://sumirevox.com
ADMIN_DOMAIN=https://admin.sumirevox.com

# Session
SESSION_SECRET=（openssl rand -hex 32 等でランダムな文字列を生成）

# CORS (Cloudflare Pages のドメインを許可)
CORS_ORIGIN=https://sumirevox.com,https://admin.sumirevox.com

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# VOICEVOX (Docker ネットワーク内)
VOICEVOX_URLS=http://voicevox:50021

# Bot
BOT_ADMIN_USER_IDS=
GLOBAL_DICT_NOTIFICATION_CHANNEL_ID=
DEFAULT_SPEAKER_ID=1
BOT_INSTANCE_ID=1

# Optional
BOOST_COOLDOWN_DAYS=7
LOG_LEVEL=info
API_PORT=3000
MAX_CONCURRENT_SYNTHESIS_PER_GUILD=3
MAX_CONCURRENT_SYNTHESIS_GLOBAL=10
SETTINGS_CACHE_TTL_SECONDS=300
HEALTH_CHECK_INTERVAL_SECONDS=60
VOICE_DISCONNECT_TIMEOUT_SECONDS=300
